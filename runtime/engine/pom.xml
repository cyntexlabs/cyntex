<?xml version="1.0" encoding="UTF-8"?>
<project xmlns="http://maven.apache.org/POM/4.0.0"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 http://maven.apache.org/xsd/maven-4.0.0.xsd">
  <modelVersion>4.0.0</modelVersion>

  <parent>
    <groupId>io.cyntex</groupId>
    <artifactId>runtime</artifactId>
    <version>${revision}</version>
  </parent>

  <artifactId>engine</artifactId>
  <name>Cyntex :: Runtime :: Engine</name>
  <description>Data-plane execution (the pipeline runtime): the Jet job lifecycle actuator (submit /
    suspend / resume / cancel) that maps a pipeline's lifecycle to its Jet job, the generic adapters that
    wrap a stateless transform port and a sink writer into Jet processors, and the construction of a
    pipeline's Jet DAG. Depends on core + spi and the Hazelcast execution substrate only (rule R4);
    never on an adapter.</description>

  <dependencies>
    <!-- The resource model the DAG builder reads to compile a pipeline into a Jet job; core ring,
         zero third-party (rule R4: core + spi only). -->
    <dependency>
      <groupId>io.cyntex</groupId>
      <artifactId>core-model</artifactId>
      <version>${revision}</version>
    </dependency>

    <!-- The stateless transform seam the runtime adapter wraps; brings the event envelope currency
         transitively (rule R4: core + spi only). -->
    <dependency>
      <groupId>io.cyntex</groupId>
      <artifactId>spi-transform</artifactId>
      <version>${revision}</version>
    </dependency>

    <!-- The write-side sink seam the runtime adapter drives: the generic sink processor batches
         events into a SinkWriter and paces its in-flight writes. A pure spi contract; the connector
         type never reaches the engine (rule R4: core + spi only). -->
    <dependency>
      <groupId>io.cyntex</groupId>
      <artifactId>spi-sink</artifactId>
      <version>${revision}</version>
    </dependency>

    <!-- The execution substrate: the member and the Jet engine ship in this one artifact (rule R4:
         Hazelcast is the one allowed substrate for the runtime ring); the actuator submits / suspends /
         resumes / cancels Jet jobs on it. Version managed by the bom. -->
    <dependency>
      <groupId>com.hazelcast</groupId>
      <artifactId>hazelcast</artifactId>
    </dependency>
    <!-- The error-code contract for diagnosable job-operation failures (rule R4: core only). -->
    <dependency>
      <groupId>io.cyntex</groupId>
      <artifactId>core-common</artifactId>
      <version>${revision}</version>
    </dependency>

    <dependency>
      <groupId>org.junit.jupiter</groupId>
      <artifactId>junit-jupiter</artifactId>
      <scope>test</scope>
    </dependency>
    <dependency>
      <groupId>org.assertj</groupId>
      <artifactId>assertj-core</artifactId>
      <scope>test</scope>
    </dependency>
  </dependencies>
</project>
