{
  "properties": {
    "name": "Coding",
    "realName": "Coding",
    "icon": "icons/coding.png",
    "doc": "${doc}",
    "id": "coding",
    "tags": [
      "SaaS"
    ]
  },
  "configOptions": {
    "pdkExpansion": [],
    "node": {
      "type": "object",
      "properties": {
        "DescribeIterationList": {
          "type": "string",
          "x-display": "hidden"
        },
        "DescribeIterationArray": {
          "x-decorator": "FormItem",
          "x-component": "AsyncSelect",
          "x-component-props": {
            "method": "{{loadCommandList}}",
            "params": "{{ {$values: $values, command: \"DescribeIterationList\"} }}",
            "multiple": true,
            "currentLabel": "{{ $values.nodeConfig.DescribeIterationArrayLabel }}",
            "@change-label": "{{ val => $values.nodeConfig.DescribeIterationArrayLabel = val }}",
            "@change": "{{ val => $values.nodeConfig.DescribeIterationList = val.join() || \"-1\" }}"
          },
          "title": "${iterationCodes}",
          "type": "array",
          "x-index": 0
        },
        "issueType": {
          "type": "String",
          "default": "ALL",
          "title": "${issueType}",
          "x-decorator": "FormItem",
          "x-component": "Select",
          "enum": [
            {
              "label": "${allIssueType}",
              "value": "ALL"
            },
            {
              "label": "${defectIssue}",
              "value": "DEFECT"
            },
            {
              "label": "${requirementIssue}",
              "value": "REQUIREMENT"
            },
            {
              "label": "${missionIssue}",
              "value": "MISSION"
            },
            {
              "label": "${epicIssue}",
              "value": "EPIC"
            }
          ],
          "x-index": 2,
          "required": false
        }
      }
    },
    "connection": {
      "type": "object",
      "properties": {
        "teamName": {
          "type": "String",
          "title": "${teamName}",
          "x-decorator": "FormItem",
          "x-component": "Input",
          "apiServerKey": "database_host",
          "x-index": 10,
          "required": true
        },
        "token": {
          "type": "String",
          "title": "${token}",
          "x-decorator": "FormItem",
          "x-component": "Input",
          "apiServerKey": "database_host",
          "x-index": 20,
          "required": true
        },
        "projectName": {
          "title": "${projectName}",
          "type": "string",
          "required": true,
          "x-decorator": "FormItem",
          "x-component": "AsyncSelect",
          "x-component-props": {
            "method": "{{loadCommandList}}",
            "params": "{{ {$values: $values, command: \"DescribeUserProjects\"} }}"
          },
          "x-index": 30,
          "x-reactions": [
            {
              "dependencies": [
                "teamName",
                "token"
              ],
              "fulfill": {
                "state": {
                  "display": "{{$deps[0]&&$deps[1] ? \"visible\":\"hidden\"}}"
                }
              }
            }
          ]
        },
        "connectionMode": {
          "type": "String",
          "default": "DocumentMode",
          "title": "${connectionMode}",
          "x-decorator": "FormItem",
          "x-component": "Select",
          "enum": [
            {
              "label": "${document}",
              "value": "DocumentMode"
            }
          ],
          "x-index": 40,
          "required": false
        },
        "streamReadType": {
          "type": "String",
          "default": "WebHook",
          "title": "${streamReadType}",
          "x-decorator": "FormItem",
          "x-component": "Select",
          "enum": [
            {
              "label": "${webHookRead}",
              "value": "WebHook"
            },
            {
              "label": "${pollingRead}",
              "value": "Polling"
            }
          ],
          "x-index": 50,
          "required": false
        },
        "hookButton": {
          "type": "void",
          "title": "${hookButton}",
          "x-decorator": "FormItem",
          "x-component-props": {
            "onClick": "{{useAsyncDataSourceByConfig({service: getToken, withoutField: true}, {name:'hookText'}, $values, $form)}}"
          },
          "x-reactions": {
            "dependencies": [
              "streamReadType"
            ],
            "fulfill": {
              "state": {
                "display": "{{$deps[0] === \"WebHook\" ? \"visible\" : \"hidden\"}}"
              }
            }
          },
          "x-content": "hookButton",
          "x-component": "Button",
          "x-index": 60
        },
        "hookText": {
          "type": "string",
          "title": " ",
          "x-decorator": "FormItem",
          "x-decorator-props": {
            "colon": false
          },
          "x-reactions": {
            "dependencies": [
              "streamReadType"
            ],
            "fulfill": {
              "state": {
                "display": "{{$deps[0] === \"WebHook\" ? \"visible\" : \"hidden\"}}"
              }
            }
          },
          "x-component": "Input",
          "x-index": 70,
          "actionOnCopy": "NEW_WEB_HOOK_URL"
        }
      }
    }
  },
  "messages": {
    "default": "en_US",
    "en_US": {
      "token": "Token",
      "projectName": "project name",
      "teamName": "Team name",
      "webHook": "Service Hook",
      "hookButton": "Generate Service URL",
      "iterationCodes": "Iteration",
      "issueType": "Issue Type",
      "allIssueType": "All Issue",
      "defectIssue": "Defect",
      "requirementIssue": "Requirement",
      "missionIssue": "Mission",
      "epicIssue": "Epic",
      "connectionMode": "Connection mode",
      "document": "General document",
      "csv": "CSV format",
      "streamReadType": "Incremental mode",
      "webHookRead": "Web Hook",
      "pollingRead": "Polling Read",
      "doc": "docs/coding_en_US.md"
    }
  },
  "dataTypes": {
    "StringLonger": {
      "to": "TapString",
      "byte": "1m"
    },
    "StringNormal": {
      "to": "TapString",
      "byte": 2048
    },
    "StringSmaller": {
      "to": "TapString",
      "byte": 512
    },
    "StringMinor": {
      "to": "TapString",
      "byte": 256
    },
    "StringBit": {
      "to": "TapString",
      "byte": 20
    },
    "Integer": {
      "to": "TapNumber",
      "value": [
        -2147483648,
        2147483647
      ]
    },
    "Boolean": {
      "to": "TapBoolean"
    },
    "Map": {
      "to": "TapMap"
    },
    "Long": {
      "to": "TapNumber",
      "value": [
        -9223372036854775808,
        9223372036854775807
      ]
    },
    "WorkingHours": {
      "to": "TapNumber",
      "value": [
        0.0,
        10000.0
      ],
      "scale": [
        0,
        2
      ]
    },
    "Float": {
      "to": "TapNumber",
      "precision": [
        1,
        30
      ],
      "value": [
        -3.402823466e+38,
        3.402823466e+38
      ],
      "scale": [
        0,
        30
      ],
      "fixed": false
    },
    "Array": {
      "to": "TapArray"
    },
    "NULL": {
      "to": "TapRaw"
    }
  }
}
