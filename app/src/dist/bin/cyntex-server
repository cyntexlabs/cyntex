#!/usr/bin/env bash
#
# Cyntex server launcher: brings the platform up in one process from the unpacked distribution.
#
# Resolves its own location so the distribution is relocatable, then runs the bundled fat-jar with
# conf/ added to the configuration search path (files there override the jar-internal defaults).
# Arguments are forwarded to the server (e.g. --role=all, which is also the default when none is
# given). Override the JVM flags via JAVA_OPTS and the Java binary via JAVA_HOME.
set -euo pipefail

APP_HOME="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
JAVA_BIN="${JAVA_HOME:+$JAVA_HOME/bin/}java"

# the single runnable fat-jar shipped in lib/
JAR="$(ls "$APP_HOME"/lib/*.jar | head -1)"

# Run from the installation directory so relative paths resolve deterministically under the install
# home rather than the caller's working directory — in particular the default operational log
# directory (cyntex.log.dir=logs). Operator overrides (conf/, environment, --flags) keep their normal
# Spring precedence, so this only pins the default; it does not clobber a configured path.
cd "$APP_HOME"

# JAVA_OPTS is intentionally word-split so multiple flags can be passed in one variable.
exec "$JAVA_BIN" ${JAVA_OPTS:-} -jar "$JAR" \
  --spring.config.additional-location="file:$APP_HOME/conf/" \
  "$@"
