<?xml version="1.0" encoding="UTF-8"?>
<project xmlns="http://maven.apache.org/POM/4.0.0"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 http://maven.apache.org/xsd/maven-4.0.0.xsd">
  <modelVersion>4.0.0</modelVersion>

  <parent>
    <groupId>io.cyntex</groupId>
    <artifactId>adapters</artifactId>
    <version>${revision}</version>
  </parent>

  <artifactId>adapter-pdk</artifactId>
  <name>Cyntex :: Adapters :: PDK</name>
  <!-- The only module allowed to import the PDK API (rule R3). It compiles against the frozen PDK
       contract (tapdata-pdk-api) — the shared layer the isolated connector class loaders delegate to.
       The connector plugins are never compile dependencies (they load at runtime inside per-connector
       class loaders). The PDK runtime is not a compile dependency either, but it cannot live inside the
       isolated connector loader: a connector's base class bootstraps the runtime through the host class
       loader, so the runtime must be host-reachable. The default build stays PDK-runtime-free; the
       runtime is provided on the host test classpath only under the pdk-it profile (real-connector
       regression) below. -->
  <description>PDK runtime bridge: isolated per-connector class loading over the frozen PDK contract (capture + sink adapter)</description>

  <dependencies>
    <!-- The frozen PDK contract surface (rule R3 locks it to this module). Compile scope: it is the
         shared API the per-connector class loaders expose to connectors, so it must sit on the host
         classpath as the one contract every connector binds to. -->
    <dependency>
      <groupId>io.tapdata</groupId>
      <artifactId>tapdata-pdk-api</artifactId>
    </dependency>

    <!-- The event envelope this bridge projects PDK TapEvents to and from — the shared currency the
         spi ports carry (core ring, zero third-party). Compile scope: the codec's signatures are in
         terms of it. -->
    <dependency>
      <groupId>io.cyntex</groupId>
      <artifactId>core-event</artifactId>
      <version>${revision}</version>
    </dependency>

    <!-- The error-code contract (core ring, zero third-party): the bridge raises its diagnosable
         load / level / projection failures as coded exceptions in the connector domain. Compile
         scope: the throw sites reference the code enum and the exception carrier directly. -->
    <dependency>
      <groupId>io.cyntex</groupId>
      <artifactId>core-common</artifactId>
      <version>${revision}</version>
    </dependency>

    <!-- The read/write port contracts this bridge implements (spi ring, over the event envelope).
         adapter -> spi is the port-adapter direction: the bridge is the PDK implementation of these
         ports, so runtime/control depend on the ports, never on this module. -->
    <dependency>
      <groupId>io.cyntex</groupId>
      <artifactId>spi-capture</artifactId>
      <version>${revision}</version>
    </dependency>
    <dependency>
      <groupId>io.cyntex</groupId>
      <artifactId>spi-sink</artifactId>
      <version>${revision}</version>
    </dependency>
    <!-- The connection-test result contract (spi ring): the connection tester normalizes the frozen
         PDK connectionTest into this module's ConnectionTestResult; ConnectionConfig is its input. -->
    <dependency>
      <groupId>io.cyntex</groupId>
      <artifactId>spi-store</artifactId>
      <version>${revision}</version>
    </dependency>

    <!-- The catalog normalization + assembly the register path runs at runtime: after a connector is
         registered, its declared capability ids are merged with its normalized spec into a catalog row
         (SpecNormalizer / CatalogEntryAssembler), reusing the same model the offline build recorded so
         the online and bundled catalogs agree. An adapters-ring module depending on the core ring. -->
    <dependency>
      <groupId>io.cyntex</groupId>
      <artifactId>core-catalog</artifactId>
      <version>${revision}</version>
    </dependency>

    <dependency>
      <groupId>org.junit.jupiter</groupId>
      <artifactId>junit-jupiter</artifactId>
      <scope>test</scope>
    </dependency>
    <dependency>
      <groupId>org.assertj</groupId>
      <artifactId>assertj-core</artifactId>
      <scope>test</scope>
    </dependency>
  </dependencies>

  <profiles>
    <!-- Real-connector regression. Activated by the same property the gated test keys on, so
         `mvn -pl adapters/adapter-pdk test -Dcyntex.pdk.it.jarA=... -Dcyntex.pdk.it.classA=... -Dcyntex.pdk.it.idA=...`
         both selects the test and puts the PDK runtime on the host classpath. A connector dist jar is a
         thin plugin whose base class bootstraps the PDK runtime (TapRuntime, plus the error-code types it
         references) via the host class loader, so the runtime must be host-reachable — it cannot ride in
         the isolated connector loader. Test scope, so the default build never carries it and stays
         PDK-runtime-free.

         The runtime pulls its own transitive tree (ehcache, reflections, jaxb, jjwt, cglib, fastjson, the
         tapdata error-code libraries). That tree resolves cleanly under the full enforcer — no rule is
         relaxed for this profile: it converges, respects the upper-bound gate, and (crucially for rule
         R3) carries no Spring and no Hazelcast, so the adapters-ring cross-ring blacklist stays fully in
         force and green. The compile surface is unchanged (tapdata-pdk-api only), so the ArchUnit R3
         import lock is untouched. -->
    <profile>
      <id>pdk-it</id>
      <activation>
        <property>
          <name>cyntex.pdk.it.jarA</name>
        </property>
      </activation>
      <dependencies>
        <dependency>
          <groupId>io.tapdata</groupId>
          <artifactId>tapdata-pdk-runner</artifactId>
          <scope>test</scope>
        </dependency>
      </dependencies>
    </profile>
  </profiles>
</project>
